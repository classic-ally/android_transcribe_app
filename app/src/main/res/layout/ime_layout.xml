<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?attr/colorSurface"
    android:padding="12dp">

    <!-- Status row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/ime_status_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tap to speak"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:paddingStart="4dp"/>

        <ProgressBar
            android:id="@+id/ime_progress"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- Live streaming preview strip (opt-in). Italic = in-progress, not yet
         committed. Single line, ellipsized at the start so the most recent
         words stay visible. Hidden unless a preview hypothesis arrives. -->
    <TextView
        android:id="@+id/ime_preview_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="20dp"
        android:visibility="gone"
        android:textAppearance="?attr/textAppearanceBodySmall"
        android:textStyle="italic"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:maxLines="1"
        android:singleLine="true"
        android:ellipsize="start"
        android:paddingHorizontal="4dp"
        android:paddingBottom="4dp"/>

    <!-- Record area: pulsing mic-level glow behind a circular record button -->
    <FrameLayout
        android:id="@+id/ime_record_container"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:clickable="true"
        android:focusable="true">

        <dev.notune.transcribe.MicLevelView
            android:id="@+id/ime_mic_level"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="center"/>

        <View
            android:id="@+id/ime_record_circle"
            android:layout_width="104dp"
            android:layout_height="104dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_ime_record"/>

        <ImageView
            android:id="@+id/ime_mic_icon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_mic"
            android:layout_gravity="center"
            android:contentDescription="@string/section_ime"/>

        <TextView
            android:id="@+id/ime_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap to Record"
            android:layout_gravity="center_horizontal|bottom"
            android:layout_marginBottom="12dp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textAppearance="?attr/textAppearanceBodySmall"/>
    </FrameLayout>

    <!-- Bottom key row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false"
        android:paddingTop="8dp">

        <ImageView
            android:id="@+id/ime_switch_keyboard"
            android:layout_width="52dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_keyboard_switch"
            android:scaleType="centerInside"
            android:background="@drawable/bg_ime_key"
            android:tint="?attr/colorOnSurfaceVariant"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="8dp"
            android:contentDescription="Switch keyboard"/>

        <ImageView
            android:id="@+id/ime_space"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:src="@drawable/ic_space"
            android:scaleType="centerInside"
            android:background="@drawable/bg_ime_key"
            android:tint="?attr/colorOnSurfaceVariant"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="8dp"
            android:contentDescription="Space"/>

        <ImageView
            android:id="@+id/ime_enter"
            android:layout_width="64dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_enter"
            android:scaleType="centerInside"
            android:background="@drawable/bg_ime_key"
            android:tint="?attr/colorOnSurfaceVariant"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="8dp"
            android:contentDescription="Enter"/>

        <ImageView
            android:id="@+id/ime_backspace"
            android:layout_width="64dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_backspace"
            android:scaleType="centerInside"
            android:background="@drawable/bg_ime_key"
            android:tint="?attr/colorOnSurfaceVariant"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Backspace"/>
    </LinearLayout>

</LinearLayout>
