<resources>
    <!-- Dark overrides for the keyboard/IME palette. The main app uses Material 3
         theme attributes (colorSurface/colorOnSurface/…) which adapt to dark mode
         automatically, so only the IME's explicit colors need night variants. -->
    <color name="ime_bg">#1E1E1E</color>
    <color name="ime_card_bg">#2A2A2A</color>
    <color name="ime_text">#ECECEC</color>
    <color name="ime_hint">#9E9E9E</color>
    <color name="ime_key_bg">#3A3A3A</color>
</resources>
